                "response": CLARIFY_QUESTIONS[next_q],
                "mode": "credit",
            }

    # ✅ All signals collected → move to planning
    session["state"] = "planning"
    session["clarifying_question"] = None
    return handle_planning_state(text, session)


def handle_projection_logic(text: str, session: dict) -> dict:
    text_lower = text.lower()
    score = session.get("score_shared")

    awaiting_score = session.get("awaiting_score")

    if not awaiting_score and "projection" not in text_lower and "show my" not in text_lower:
        return None

    if not score:
        session["awaiting_score"] = True
        return {
            "response": "I need your credit score to build a projection. What's your current score?",
            "mode": "credit"
        }

    session["awaiting_score"] = False

    topic = session.get("projection_topic") or session.get("last_topic", "general_credit")

    if topic not in SCORE_SIMULATION_RANGES:
        topic = "utilization"

    scenario_key = list(SCORE_SIMULATION_RANGES[topic]["improvement_ranges"].keys())[0]
    projection = generate_score_projection(score, topic, scenario_key)

    return {
        "response": f"Here's your score projection starting from {score}:",
        "mode": "credit",
        "projection_data": projection,
        "show_projection_chart": True
    }


