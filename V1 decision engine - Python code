# LAYER 1 — INTENT CLASSIFICATION
# Determines WHY the user is asking, not just what they're asking about
# ===========================================================================

def classify_intent(text: str) -> str:
    """
    Returns one of: learn | improve | diagnose | decide | unknown

    Scoring:
      - Full phrase match = 3 points
      - Partial word overlap = 0.7 per word
      - Threshold: 1.5 to assign an intent
      this is the number range to match a user input as an efficient response.
    """
    text_lower = text.lower()

    # Instant activation words (classify_intent is a second router)
    if is_decide_question(text_lower):
        return "decide"

    if is_diagnose_question(text_lower):
        return "diagnose"

    if is_improve_question(text_lower):
        return "improve"

    if is_learn_question(text):
        return "learn"

    return "unknown"


# ===========================================================================
# LAYER 2 — CONCEPT RETRIEVAL
# Finds the most relevant knowledge topic given the text
# ===========================================================================
def retrieve_concept(user_input: str) -> tuple[str, float]:
    text = user_input.lower()
    scores = {}

    for topic, keywords in TOPIC_KEYWORDS.items():
        score = 0
        for phrase in keywords:
            # AI generated word regex to allow for no inconsistent word matching.
            if len(phrase.split()) > 1:
                matched = phrase in text
            else:
                matched = re.search(rf"\b{re.escape(phrase)}\b", text) is not None

            if matched:
                score += len(
                    phrase.split())  # prioritize longer, more specific phrases biggest phrase wins, ruling out the general credit biasedness.
        scores[topic] = score

        for boost_word in BOOST_WORDS.get(topic, []):
            if boost_word in text:
                score += 2

        scores[topic] = score

    best_topic = max(scores, key=scores.get)
    best_score = scores[best_topic]
    total = sum(scores.values())

    if best_score < 2:
        return "general_credit", 0.2

    confidence = best_score / (total if total else 1)
    return best_topic, confidence


