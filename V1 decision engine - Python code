def apply_reasoning(intent: str, topic_key: str | None, score: int | None, signals: dict = None) -> dict:
    """
    Given the intent + topic + user's score, returns a reasoning block:
    {
      primary_action, secondary_action, warning,
      cause_effect, timeframe, recommendation,
      pro, con, better_alternative, root_cause
    }
    """

    result = {}

    # -----------------------------
    # Rule Lookup (Intent + Topic)
    # -----------------------------
    rule_key = f"{intent}:{topic_key}" if topic_key else None
    rule = REASONING_RULES.get(rule_key, {})
    result.update(rule)

    # -----------------------------
    # Score-Based Personalization
    # -----------------------------
    if score is not None:
        # ===== IMPROVE / DIAGNOSE =====
        if intent in ["improve", "diagnose"]:

            active_issues = (
                    signals.get("collections") == "yes"
                    or signals.get("missed_payments") == "yes"
                    or signals.get("high_utilization") == "yes"
                    or topic_key in ("collections_first", "payment_history")
            )

            if active_issues:
                result["urgency_note"] = (
                    f"Even with a {score}, these issues are actively dragging your score. "
                    f"The plan below targets exactly what's hurting you right now."
                )

            if score <= 580:
                result["primary_action"] = (
                    f"First off honesty is key a score of {score} is not where anyone wants to be.\n\n"
                    "But the good news is you can recover from this.\n\n"
                    "The fastest wins for someone with you credit profile will most certainly come from from:\n"
                    "- Fixing any payment history issues you have.\n"
                    "- Disputing errors within your account which could have caused the decrease.\n\n"
                    "Remember what's important at this stage is you take action towards the small steps. \n\n"
                    "But I recommend you keep your main focus on these steps..."
                )

            elif score < 740:
                result["urgency_note"] = (
                    f"With a score of {score},  your system is already working well.\n\n"
                    "To break into the 750+ (A+ tier) zone your best options are:\n"
                    "- Get utilization under 10%\n"
                    "- Maintain 12 months of clean history\n\n"
                    "While these help, I'd recommend you remember remember these steps..."
                )

            else:
                result["urgency_note"] = (
                    f"A {score} is an impressive place to be.\n\n"
                    "But to keep it at this level, I recommend you build for protection by doing things like:\n"
                    "- Keeping utilization under 10%\n"
                    "- Avoiding unnecessary accounts\n"
                    "- Being patient, and knowing that time will most certainly do the rest. \n\n"
                    "Stick to these simple steps..."
                )

        # ===== DECISION =====
        if intent == "decide":

            if score >= 610:
                result["urgency_note"] = (
                    "Now at this stage you might be wondering:\n"
                    "“Should I close this card?” 💭\n\n"
                    "Short answer: don’t.\n\n"
                    "Instead:\n"
                    "- Focus on paying down interest\n"
                    "- Start with the highest interest card\n"
                    "- Go one at a time\n\n"
                    "Slow and consistent wins here."
                )

            elif 620 < score < 800:
                result["urgency_note"] = (
                    f"You're in a strong position with a score of {score}.\n\n"
                    "Now it's about discipline to push higher:\n\n"
                    "1. Never miss payments (autopay helps)\n"
                    "2. Avoid spending that creates future stress\n"
                    "3. Keep utilization under 30%\n\n"
                    "This is where good habits turn into elite results."
                )

            else:
                result["primary_action"] = (
                    "Pause for a second — seriously.\n\n"
                    "You're operating at an elite level (top 0.01%).\n\n"
                    "At this point:\n"
                    "- Don’t overcomplicate things\n"
                    "- Stay consistent\n"
                    "- Protect your foundation\n\n"
                    "Keep your rhythm and let the system reward you. 🕊️"
                )

        if topic_key in SCORE_SIMULATION_RANGES:

            result["projection_topic"] = topic_key

            # Decide the direct projection to give when the topic key is a specific value.
            if topic_key == "utilization":
                if score >= 740:

                    result["projection_scenario"] = "slight_reduce"
                elif score >= 620:
                    result["projection_scenario"] = "mid_to_low"
                else:
                    result["projection_scenario"] = "high_to_low"

            elif topic_key == "collections":
