        handle_projection_logic(text, session)

    # --- CONTEXT SIGNALS ---
    same_topic = previous_topic == topic_key
    follow_up = _is_follow_up(text)
    appreciation = is_appreciation(text)

    intent_allows = intent in {"learn", "improve", "diagnose"}

    # --- EXPANSION LOGIC ---
    force_expand = appreciation and same_topic
    conditional_expand = same_topic and intent_allows and follow_up

    if force_expand or conditional_expand:
        knowledge_text = topic_data.get("elaboration", knowledge_text)

    # --- PREFIX (tone only, not logic) ---
    prefix = ""
    if force_expand:
        prefix = get_appreciation_prefix() + "Here's how you can actually apply this:\n\n"

    print("Is Same Topic:", previous_topic == topic_key)
    print("Is Follow Up:", _is_follow_up(text))
    print("User typed in appreciation:", is_appreciation(text))

    # --- FINAL RESPONSE ---
    response_text = (
            opener
            + prefix
            + knowledge_text
            + "\n\n "
            + reasoning_prefix
            + separator
            + plan_text
    )

    # Store state
    session["current_plan"] = plan

    # Set the current plan saved so that the data can be used and viewed.
    session.setdefault("plans_given", [])
    session["plans_given"].append({
        "topic": topic_key,
        "date": datetime.datetime.now().isoformat(),
        "completed": False
    })

    session["state"] = "plan_given"

    book = _recommend_audiobook(text, session)
    record_feedback(session, intent, topic_key)
    _push_credit_history(session, "assistant", response_text)

    if session.get("score_shared"):
        session["projection_ready"] = True
        session["projection_topic"] = topic_key

        return {
            "response": response_text + "\n\nWant to see what this could look like over the next few months? I can show you a realistic range based on your score.",
            "mode": "credit",
            "show_projection_prompt": True
        }

    print("\n[RESPONSE DEBUG]")
    print("FINAL TOPIC:", topic_key)
    print("STATE SET TO:", session.get("state"))
    print("RESPONSE LENGTH:", len(response_text))
    print("----------------------\n")

    return {
        "response": response_text,
        "mode": "credit",
        "suggest_books": book is not None,
        "book": book,
    }


def handle_explain_state(text: str, session: dict) -> dict:
    print(f"[EXPLAIN STATE] text received: {text}")

    last_topic = session.get("last_topic")

    # Follow-up on same topic if user is drilling deeper
    if _is_follow_up(text) and session.get("last_topic"):
        topic_key = session["last_topic"]
    else:
        # Try exact keyword match first, then scored retrieval
        topic_key = retrieve_concept(text)[0]

        if topic_key == "general_credit" and last_topic and last_topic != "general_credit":
            topic_key = last_topic

    session["last_topic"] = topic_key
    session["last_intent"] = "learn"

    topic_data = CREDIT_KNOWLEDGE.get(topic_key) or CREDIT_KNOWLEDGE["score_ranges"]
    body = topic_data.get("response", "")

    # Prefer elaboration if user is following up, otherwise base response
    if _is_follow_up(text) and topic_data.get("elaboration"):
        body = topic_data["elaboration"]

    emotion = _detect_credit_emotion(text)
    opener = _get_credit_opener(emotion, text) if emotion else ""

    response_text = opener + body

    book = _recommend_audiobook(text, session)
    record_feedback(session, "learn", topic_key)
    _push_credit_history(session, "assistant", response_text)

    session["state"] = "normal"

    return {
        "response": response_text,
        "mode": "credit",
        "suggest_books": book is not None,
        "book": book,
    }


def handle_decision_state(text: str, session: dict, reasoning: dict = None) -> dict:
    projection = handle_projection_logic(text, session)
    if projection: return projection

    # If the user wants to learn something mid-decision, detour then come back
    intent = classify_intent(text)
    if intent == "learn":
        session["return_to_state"] = "decision"
        session["state"] = "explain"
        return handle_explain_state(text, session)

    improve_signals = [
        "start building", "build my credit", "start credit",
        "begin building", "how do i start", "where do i start",
        "get started", "begin credit", "first step"
    ]

    text_lower = text.lower()
    if any(sig in text_lower for sig in improve_signals):
        session["state"] = "clarifying"
        session["clarifying_state"] = "has_credit_card"
        session["last_intent"] = "improve"
        return handle_smart_message(text, session)

    topic_key = retrieve_concept(text)[0]
    session["last_topic"] = topic_key

    topic_data = CREDIT_KNOWLEDGE.get(topic_key) or CREDIT_KNOWLEDGE["score_ranges"]

    if reasoning is None:
        reasoning = apply_reasoning("decide", topic_key, session.get("score_shared"))

    lines = ["Here's how to think about this decision:\n"]

    # Pull structured fields from topic_data if they exist
    if topic_data.get("pros"):
        lines.append("Pros:")
        lines.extend(f"  • {p}" for p in topic_data["pros"])

    if topic_data.get("cons"):
        lines.append("Cons:")
        lines.extend(f"  • {c}" for c in topic_data["cons"])

    if topic_data.get("impact"):
        lines.append(f"\nCredit impact: {topic_data['impact']}")

    # Layer in reasoning-engine output
    if reasoning.get("recommendation"):
        lines.append(f"\nRecommendation: {reasoning['recommendation']}")
    if reasoning.get("pro"):
        lines.append(f"Pro: {reasoning['pro']}")
    if reasoning.get("con"):
        lines.append(f"Con: {reasoning['con']}")
    if reasoning.get("better_alternative"):
        lines.append(f"Better option: {reasoning['better_alternative']}")
    if reasoning.get("cause_effect"):
        lines.append(f"\nImpact: {reasoning['cause_effect']}")
    if reasoning.get("urgency_note"):
        lines.append(f"\n{reasoning['urgency_note']}")

    urgency = reasoning.get("urgency_note", "")
    if urgency and topic_key not in ("general_credit", "build_from_zero"):
        lines.append(f"\n {urgency} ")

    # If none of the structured fields fired, fall back to the topic's base response
    if len(lines) == 1:
        # Pull the first unanswered decide clarification question
        tree = CLARIFY_TREE.get("decide", {}).get("general_credit", [])
        asked = session.get("clarify_asked", [])

        next_question = None
        for key, question in tree:
            if key not in asked:
                session.setdefault("clarify_asked", []).append(key)
                session["clarifying_question"] = key
                session["state"] = "clarifying"
                next_question = question
                break

        if next_question:
            _push_credit_history(session, "assistant", next_question)
            return {"response": next_question, "mode": "credit"}

        # All clarification exhausted — now route to planning with what we have
        session["state"] = "planning"
        session["last_intent"] = "decide"
        return handle_planning_state(text, session)

    response_text = "\n".join(lines)

    record_feedback(session, "decide", topic_key)
    _push_credit_history(session, "assistant", response_text)
    session["state"] = "normal"

    return {
        "response": response_text,
        "mode": "credit",
    }


