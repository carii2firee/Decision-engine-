# UI handler to display the dict data for the visual graph.
def generate_score_projection(current_score, topic, scenario_key):
    ranges = SCORE_SIMULATION_RANGES[topic]["improvement_ranges"][scenario_key]
    timeline = SCORE_SIMULATION_RANGES[topic]["timeline_months"]

    projection = [{"month": 0, "low": current_score, "high": current_score}]

    running_low = current_score
    running_high = current_score

    # Score tier ceilings — prevents projection from overshooting realistic limits
    # based on what each action can actually achieve
    REALISTIC_CEILINGS = {
        "pay_for_delete":             150,  # max total gain from removing a collection
        "pay_for_delete_last_one":    180,
        "pay_for_delete_multi_remaining": 20,
        "paid_in_full":               40,
        "settled":                    25,
        "high_to_low":                90,   # utilization drop max
        "mid_to_low":                 45,
        "slight_reduce":              20,
        "clean_streak":               75,   # 12 months clean history
        "goodwill_removal":           80,
        "secured_card":               120,  # building from zero over 12 months
    }

    total_gain_low = 0
    total_gain_high = 0
    ceiling = REALISTIC_CEILINGS.get(scenario_key, 100)

    for i, month in enumerate(timeline):
        low_gain, high_gain = ranges[i]

        # build_from_zero: no score exists before month 6
        # treat as absolute target range instead of additive gain
        if topic == "build_from_zero" and scenario_key == "secured_card":
            if low_gain == 0 and high_gain == 0:
                projection.append({
                    "month": month,
                    "low": 0,
                    "high": 0,
                    "label": f"Month {month} (no score yet)"
                })
                continue
            else:
                # month 12 — first real score appears
                projection.append({
                    "month": month,
                    "low": low_gain,   # these are absolute targets e.g. 620
                    "high": high_gain, # e.g. 680
                    "label": f"Month {month}"
                })
                continue

        # all other topics — additive gains with ceiling enforcement
        remaining_low = max(0, ceiling - total_gain_low)
        remaining_high = max(0, ceiling - total_gain_high)

        actual_low = min(low_gain, remaining_low)
        actual_high = min(high_gain, remaining_high)

        running_low = min(850, running_low + actual_low)
        running_high = min(850, running_high + actual_high)

        total_gain_low += actual_low
        total_gain_high += actual_high

        projection.append({
            "month": month,
            "low": running_low,
            "high": running_high,
            "label": f"Month {month}"
        })

    return projection


