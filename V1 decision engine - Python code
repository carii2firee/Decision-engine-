def retrieve_concept(user_input: str) -> tuple[str, float]:
    text = " ".join(user_input.lower().split())
    scores = {}

    for topic, keywords in TOPIC_KEYWORDS.items():
        score = 0
        for phrase in keywords:
            # AI generated word regex to allow for no inconsistent word matching.
            if len(phrase.split()) > 1:
                matched = phrase in text
            else:
                matched = re.search(rf"\b{re.escape(phrase)}\b", text) is not None

            if matched:
                score += len(
                    phrase.split())  # prioritize longer, more specific phrases biggest phrase wins, ruling out the general credit biasedness.
        scores[topic] = score

        for boost_word in BOOST_WORDS.get(topic, []):
            if boost_word in text:
                score += 2

        scores[topic] = score

    best_topic = max(scores, key=scores.get)
    best_score = scores[best_topic]
    total = sum(scores.values())

    if best_score < 2:
        return "general_credit", 0.2

    confidence = best_score / (total if total else 1)
    return best_topic, confidence


