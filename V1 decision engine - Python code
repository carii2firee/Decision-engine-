def make_json_safe(obj):
    if isinstance(obj, dict):
        return {k: make_json_safe(v) for k, v in obj.items()
                if not callable(v)}
    elif isinstance(obj, list):
        return [make_json_safe(i) for i in obj if not callable(i)]
    elif callable(obj):
        return None
    return obj


