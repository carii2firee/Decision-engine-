# return the yes or no words mapper (made to help wrin understand NLP)
def normalize_yes_no(text):
    text = text.lower()

    YES_WORDS = ["yes", "yeah", "yep", "y", "sure", "ok", "okay", "alright", "i do", "i have", "correct"]
    NO_WORDS = ["no", "nope", "n", "not", "don't", "do not", "never"]

    for word in YES_WORDS:
        if word in text:
            return "yes"

    for word in NO_WORDS:
        if word in text:
            return "no"

    return None


