# LAYER 1 — INTENT CLASSIFICATION
# Determines WHY the user is asking, not just what they're asking about
# ===========================================================================

def classify_intent(text: str) -> str:
    """
    Returns one of: learn | improve | diagnose | decide | unknown

    Scoring:
      - Full phrase match = 3 points
      - Partial word overlap = 0.7 per word
      - Threshold: 1.5 to assign an intent
      this is the number range to match a user input as an efficient response.
    """
    text_lower = text.lower()

    # Instant activation words (classify_intent is a second router)
    if is_decide_question(text_lower):
        return "decide"

    if is_diagnose_question(text_lower):
        return "diagnose"

    if is_improve_question(text_lower):
        return "improve"

    if is_learn_question(text):
        return "learn"

    return "unknown"


