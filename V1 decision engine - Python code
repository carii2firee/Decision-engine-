def detect_direct_path(text):
    text = text.lower()

    if "no credit" in text or "never had credit" in text:
        return "has_credit_card", "no"

    if "missed payment" in text or "late payment" in text:
        return "missed_payment", "yes"

    if "maxed out" in text or "high balance" in text:
        return "high_utilization", "yes"

    if "collections" in text:
        return "collections", "yes"

    return None


# Fish for the missing signal that the user gives off so that we can direct them to the right response to fix their problem.
def get_missing_signal(session):
    signals = session.get("signals", {})
    credit_key = ["credit_score", "has_credit_card", "high_utilization", "missed_payments", "collections"]

    for key in credit_key:
        if key == "credit_score" and session.get("score_shared"):
            continue

        if key not in signals:
            return key

    return None


# Smart handler for routing so that WRIN can give th ebest response based on what the user's needs are, and focuses on meeting it instantly.
def handle_smart_message(text: str, session: dict) -> dict:
    projection = handle_projection_logic(text, session)
    if projection:
        return projection

    """
    Single entry point that handles:
    1. Extracting and saving credit score
    2. Answering definition/concept questions from CREDIT_KNOWLEDGE
    3. If also asking how to fix → run clarification → score-aware plan
    """
    text_lower = text.lower()

    # Global appreciation logic handler.
    if is_appreciation(text):
        response = get_appreciation_prefix()
        return {"response": response, "mode": "credit"}

    # Step 1: Always extract score if present
    detected_score = _extract_credit_score(text)
    if detected_score:
        session["score_shared"] = detected_score


    #  -------- Step 2: Identify the concept they're asking about  ---------
    topic_key = retrieve_concept(text)[0]

    if topic_key and topic_key != "general_credit":
        session["last_topic"] = topic_key

    topic_data = CREDIT_KNOWLEDGE.get(topic_key)

    if not topic_data:
        topic_key = session.get("last_topic", "goal_msg")
        topic_data = CREDIT_KNOWLEDGE.get(topic_key, CREDIT_KNOWLEDGE.get("score_ranges"))

    # ── Step 3: Check what kind of message this is ────────────────────────
    wants_definition = any(s in text_lower for s in [
        "what is", "what's", "explain", "how does", "define", "whats",
        "what does", "tell me about", "what are", "what exactly", "how do I", "how is",
    ])



    wants_fix = any(s in text_lower for s in [
        "fix", "improve", "raise", "build", "how do i", "how can i",
        "what should i do", "help me", "what do i do", "steps"
    ])

    # Make sure the vague responses don't get passed as trying to draw an explanation.
    if len(text_lower.split()) <= 2:
        topic_key = session.get("last_topic", topic_key)
        wants_definition = False
        wants_fix = False

    is_follow_up = _is_follow_up(text_lower)

    if is_follow_up:
        wants_definition = True
        wants_fix = False

    parts = []

    # ── Step 4: If they want a definition, give it first ──────────────────
    if wants_definition:
        explanation = topic_data.get("response", "")
        if explanation:
            parts.append(explanation)

    # ── Step 5: If they want to fix, handle score-aware routing ───────────
    if wants_fix:
        score = session.get("score_shared")

        # If we have their score, skip clarification and go straight to plan
        if score:
            plan = build_plan(topic_key, "improve", session)
            plan_text = format_plan(plan)

            reasoning = apply_reasoning("improve", topic_key, score, signals=session.get("signals", {}))

            projection = None
            if reasoning.get("projection_topic") and reasoning.get("projection_scenario"):
                projection = generate_score_projection(
                    current_score=session["score_shared"],
                    topic=reasoning["projection_topic"],
                    scenario_key=reasoning["projection_scenario"]
                )

            reasoning_lines = []
            if reasoning.get("primary_action"):
                reasoning_lines.append(reasoning["primary_action"])
            if reasoning.get("urgency_note"):
                reasoning_lines.append(reasoning["urgency_note"])
            if reasoning.get("warning"):
                reasoning_lines.append(f"⚠ {reasoning['warning']}")

            if parts:  # already have a definition above
                parts.append("─" * 28)
                parts.append("Now here's your plan:\n")

            parts.append(plan_text)
            if reasoning_lines:
                parts.append("\n" + "\n".join(reasoning_lines))

            session["current_plan"] = plan
            session["state"] = "plan_given"
            session["last_intent"] = "improve"



        else:
            concrete_topics = {
                "build_from_zero", "utilization", "payment_history",
                "collections", "credit_age", "secured_card"
            }

            if topic_key in concrete_topics:
                plan = build_plan(topic_key, "improve", session)
                plan_text = format_plan(plan)
                parts.append(plan_text)
                session["current_plan"] = plan
                session["state"] = "normal"
                session["last_intent"] = "improve"
                session["last_topic"] = topic_key

            else:
                # Only here if topic is genuinely vague (general_credit) is predominant topic to look into, etc.)
                session["state"] = "clarifying"
                session["clarifying_question"] = "has_credit_card"
                session["last_intent"] = "improve"

                if parts:
                    parts.append("─" * 28)
                    parts.append("Now to build your plan, " + CLARIFY_QUESTIONS["has_credit_card"])
                else:
                    response_text = CLARIFY_QUESTIONS["has_credit_card"]
                    _push_credit_history(session, "assistant", response_text)
                    return {"response": response_text, "mode": "credit"}

    # ── Step 6: Stitch and return ─────────────────────────────────────────
    response_text = "\n\n".join(p for p in parts if p.strip())

    book = _recommend_audiobook(text, session)
    record_feedback(session, session.get("last_intent", "learn"), topic_key)
    _push_credit_history(session, "assistant", response_text)

    session["state"] = "normal"

    return {
        "response": response_text,
        "mode": "credit",
        "suggest_books": book is not None,
        "book": book,
    }


def handle_credit_message(user_name: str, text: str) -> dict:
    session = _get_credit_session(user_name)
    text = text.strip()
    state = session.get("state", "normal")

    # Global appreciation condition.
    if is_appreciation(text):
        response = get_appreciation_prefix()
        return {"response": response, "mode": "credit"}
    # Global back button for the user to go back if they ever want to.

    if "back" in text:
        session["state"] = "normal"

        return {"response": "Okay what's on your mind? ", "mode": "credit"}

    if not text:
        opening = _pick_opening(session)
        print("[OPENING PICKED]:", opening)
        session["turn_count"] = session.get("turn_count", 0) + 1
        _push_credit_history(session, "assistant", opening)
        save_credit_data()
        return {"response": opening, "mode": "credit"}

    _push_credit_history(session, "user", text)
    # single goal + score execution logic to run across globally.

    # pre-step: Find out what the user's credit score is.
    detected_score = _extract_credit_score(text)
    if detected_score:
        session["user_goal"] = detected_score



        session.setdefault("score_history", [])
        session["score_history"].append({
            "score": detected_score,
            "date": datetime.datetime.now().isoformat()
        })
        session.setdefault("signals", {})
        session["signals"]["credit_score"] = detected_score

        # Check for significant score change the moment a user inputs a new credit score.
        history = session["score_history"]
        if len(history) >= 2:
            previous = history[-2]["score"]
            current = history[-1]["score"]
            diff = current - previous

            if abs(diff) >= 15:
                session["score_changed"] = True
                session["score_change_delta"] = diff
                session["score_change_previous"] = previous

        # Identify and speak to the score change.
        if session.get("score_changed"):
            session["score_changed"] = False  # reset so it only fires once
            delta = session.get("score_change_delta", 0)
            previous = session.get("score_change_previous", 0)

            if delta > 0:
                return {
                    "response": (
                        f"Hold on, your score jumped {delta} points from {previous} to {detected_score}. "
                        f"That's a significant move. Keeping up habits like this is how you build the credit future "
                        f"we both know you deserve. Keep going!"
                    ),
                    "mode": "credit",
                    "score_captured": detected_score,
                }
            else:
                return {
                    "response": (
                        f"Your score dropped {abs(delta)} points from {previous} to {detected_score}. "
                        f"A drop this size usually has a clear cause,missed payment, high utilization spike, or a new hard inquiry. "
                        f"For your own benefit, please be mindful of your current situation, and remember I can build you a new plan"
                        f"that suits your current situation. Just ask (How can I fix my credit score) "
                    ),
                    "mode": "credit",
                    "score_captured": detected_score,
                }

        score_only_triggers = [
            "my credit score is",
            "my score is",
            "credit score is",
            "i have a",
            "im at",
            "i'm at",
            "my new score",
            "new score",
            "score upgrade"
        ]

        text_lower = text.lower()

        if any(trigger in text_lower for trigger in score_only_triggers):
            session["state"] = "normal"
            session["clarifying_question"] = None

            return {
                "response": f"Got it, I've just locked your credit score locked in at {detected_score}. ",
                "mode": "credit",
                "score_captured": detected_score,
            }

    if handle_user_greeting(text):
        response = (
            "Hey there friend, it's nice to meet you, while I'd love to chat. "
            "I'm focused on one thing directly, pushing you in the right direction "
            "towards having S+ tier credit, to nudge you in the right direction, "
            "I'd recommend exploring something like: 'what's my credit projection score' "
            "or ask 'how can I fix my credit score?'"
        )
        _push_credit_history(session, "assistant", response)
        save_credit_data()
        return {"response": response, "mode": "credit"}

    print(f"[ROUTER] Current state: {state}")

    if state == "plan_given":
        result = handle_plan_followup(text, session)

    elif state == "clarifying":
        result = handle_clarification_state(text, session)

    elif state == "planning":
        result = handle_planning_state(text, session)

    elif state == "explain":
        result = handle_explain_state(text, session)

    elif state == "decision":
        result = handle_decision_state(text, session)

    else:

        if session.get("current_plan"):
            plan_signals = [
                "step", "timeline", "how long", "first", "start",
                "can't", "cant", "explain step", "what do i do first"
            ]
            if any(sig in text.lower() for sig in plan_signals):
                result = handle_plan_followup(text, session)

        intent = classify_intent(text)
        session["last_intent"] = intent

        if intent in ["learn", "improve", "diagnose", "decide", ""]:
            session.pop("projection_active", None)
            session.pop("awaiting_projection_confirmation", None)
            session.pop("projection_topic", None)

        if intent == "decide":
            session["state"] = "decision"
            result = handle_decision_state(text, session)

        elif intent == "learn":
            session["state"] = "explain"
            result = handle_explain_state(text, session)

        elif intent in ("improve", "diagnose", "score_shared"):
            direct_clue = detect_direct_path(text)

            if is_projection(text) and detected_score:
                topic = session.get("projection_topic") or session.get("last_topic", "general_credit")
                if topic not in SCORE_SIMULATION_RANGES:
                    topic = "utilization"
                scenario_key = list(SCORE_SIMULATION_RANGES[topic]["improvement_ranges"].keys())[0]
                projection = generate_score_projection(detected_score, topic, scenario_key)
                save_credit_data()
                return {
                    "response": f"Here's your score projection starting from {detected_score}:",
                    "mode": "credit",
                    "projection_data": projection,
                    "show_projection_chart": True,
                    "score_captured": detected_score,
                }



            elif direct_clue:
                question, answer = direct_clue
                session.setdefault("signals", {})
                session["signals"][question] = answer
                session["state"] = "planning"
                result = handle_planning_state(text, session)

            else:
                # knowledge base gets a chance BEFORE clarification
                topic_key = retrieve_concept(text)[0]
                if topic_key and topic_key != "general_credit":
                    result = handle_smart_message(text, session)
                else:
                    session["state"] = "clarifying"
                    session["clarifying_question"] = "has_credit_card"
                    result = {"response": CLARIFY_QUESTIONS["has_credit_card"], "mode": "credit"}





        else:
            result = handle_smart_message(text, session)

    # ── Single injection point — always runs before return ────────
    if result and detected_score:
        result["score_captured"] = detected_score

    print(f"The final result in data saved is {result}")
    save_credit_data()
    return result


# return the yes or no words mapper (made to help wrin understand NLP)
def normalize_yes_no(text):
    text = text.lower()

    YES_WORDS = ["yes", "yeah", "yep", "y", "sure", "ok", "okay", "alright", "i do", "i have", "correct"]
    NO_WORDS = ["no", "nope", "n", "not", "don't", "do not", "never"]

    for word in YES_WORDS:
        if word in text:
            return "yes"

    for word in NO_WORDS:
        if word in text:
            return "no"

    return None


def handle_plan_followup(text: str, session: dict) -> dict:
    projection = handle_projection_logic(text, session)
    if projection: return projection

    text_lower = text.lower()
    plan = session.get("current_plan")

    # If user wants to learn something, detour without losing plan state
    intent = classify_intent(text)
    if intent == "learn":
        session["return_to_state"] = "plan_given"
        session["state"] = "explain"
        return handle_explain_state(text, session)

    if not plan:
        session["state"] = "normal"
        return {
            "response": "Let's start over, can you tell me what's going on with your credit.",
            "mode": "credit",
        }

    steps = plan.get("steps", [])

    # Timeline / how long questions
    if any(w in text_lower for w in
           ("how long", "timeline", "when will", "how soon", "how much time", "time length", "when will")):
        return {
            "response": f"Timeline: {plan.get('timeline', 'Depends on how consistently you follow through — most people see movement in 30–60 days.')}",
            "mode": "credit",
        }

    # First step / where to start
    if any(w in text_lower for w in
           ("first", "start", "priority", "where do i begin", "what do i do first", "whats the first step",
            "how do I even start", "whats the first move", "first action")):
        first = steps[
            0] if steps else "Focus on building a pattern of on-time payments and keeping your credit balances low."
        return {
            "response": f"Start here:\n\nStep 1: {first}",
            "mode": "credit",
        }

    # Explain a numbered step: "explain step 2"
    for i, step in enumerate(steps, 1):
        if f"step {i}" in text_lower or f"number {i}" in text_lower:
            return {
                "response": f"Step {i}, here's what this means in practice:\n\n{step}",
                "mode": "credit",
            }

    # User says they can't do something
    if any(w in text_lower for w in
           ("can't", "cant", "unable", "don't have", "don't know how", "cant even", "not possible", "wont be able",
            "sounds impossible", "will not work")):
        return {
            "response": (
                "It's fine that you feel that way, but remember to adjust, don't stop.\n\n"
                "The two things you can always control right now: "
                "pay on time (set autopay which will save you a lot of stress) and keep balances low. "
                "Starting there while you figure out the rest is the best steps towards getting you where you wanna go."
            ),
            "mode": "credit",
        }

    # Acknowledgement — wrap up plan mode cleanly
    if text_lower.strip() in ("ok", "okay", "got it", "thanks", "thank you", "makes sense", "cool"):

        if session.get("plans_given"):
            session["plans_given"][-1]["completed"] = True
        session["state"] = "normal"

        return {
            "response": "Its good we're on the same page. Come back and tell me when you've completed Step one, or if anything comes up. We will handle it step by step",
            "mode": "credit",
        }

    # Default: show the full plan again with navigation hints
    plan_text = format_plan(plan)
    return {
        "response": (
            f"Here's your plan:\n\n{plan_text}\n\n"
            "You can ask:\n"
            "• Which step should I start with?\n"
            "• How long will this take?\n"
            "• Explain step 'number one' \n"
            "• Re-enter a new credit score that you have/"
            "• I can't do the first step, what are some healthy alternatives?"
            "- 'Whats my projection' to get live visual estimates of how much your score can grow within months."
            "Whatever questions you have, I'm here to work with you through it. "
        ),
        "mode": "credit",
    }


# Fully built built_plan function that can match signals, goals, sessions, and scores to the right curated response for the user.
def build_plan(topic, intent, session):
    session = session or {}


    plan = {
        "title": "",
        "steps": [],
        "timeline": None,
        "warnings": [],
        "bottlenecks": []
    }

