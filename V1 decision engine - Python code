def _recommend_audiobook(text: str, session: dict) -> dict | None:
    text_lower = text.lower()

    for book in CREDIT_AUDIOBOOKS:
        if any(focus in text_lower for focus in book["focus"]):
            return book
    last_topic = session.get("last_topic", "")
    if last_topic in ("build_from_zero", "secured_card", "inquiries", "utilization", "credit_age"):
        return CREDIT_AUDIOBOOKS[1]
    return None


def _is_follow_up(text: str, session: dict = None) -> bool:
    text_lower = text.lower().strip()
    words = set(text_lower.split())


    # Block anything that looks like a new question
    question_starters = (
        "what", "whats", "what's", "how", "why", "where", "when",
        "who", "which", "is", "are", "can", "does", "do", "explain what",
        "tell", "define", "give"
    )
    first_word = text_lower.split()[0] if text_lower.split() else ""
    if first_word in question_starters:
        return False

    # Block conversational openers that aren't follow-ups
    if any(opener in text_lower for opener in (
        "right", "okay", "got it", "mhm",
        "explain that", "I see", "umm", "well", "err", "wow okay",
        "tell me more", "what does that mean", "here's what I heard you say"
    )):
        return False

    # Plan-state follow-up detection — only fires when user has an active plan
    if session and session.get("state") == "plan_given":
        plan = session.get("current_plan", {})

        if any(w in text_lower for w in (
            "how long", "timeline", "when will", "how soon", "how much time", "time length"
        )):
            return True

        if any(w in text_lower for w in (
            "can't", "cant", "unable", "don't have", "don't know how",
            "not possible", "wont be able", "sounds impossible", "will not work"
        )):
            return True

        if text_lower.strip() in ("ok", "okay", "got it", "thanks", "thank you", "makes sense", "cool"):
            return True


        # First step navigation
        if any(w in text_lower for w in (
            "first", "start", "priority", "where do i begin",
            "what do i do first", "whats the first step", "first move"
        )):
            return True

        # No plan question matched — not a follow-up in plan state
        return False

        # Outside plan state — standard follow-up trigger matching
    return any(
        (trigger in text_lower if " " in trigger else trigger in words)
        for trigger in FOLLOW_UP_TRIGGERS
    )



