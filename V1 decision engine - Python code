def _pick_opening(session: dict) -> str:
    # Newly added credit memory across sessions to identify if the user is improving.
    history = session.get("score_history", [])

    if len(history) >= 2:
        last = history[-2]["score"]
        current = history[-1]["score"]
        diff = current - last

        if diff > 0:
            return (
                f"Welcome back. Last time you were at {last}, now you're at {current}. "
                f"That's +{diff} points — real progress. Let's keep building on it."
            )
        elif diff < 0:
            return (
                f"Welcome back. Your score moved from {last} to {current} since we last talked. "
                f"Let's figure out what caused that drop and fix it."
            )
        else:
            return (
                f"Welcome back. You're still sitting at {current}. "
                f"Nothing lost, but let's find the next move to push it forward."
            )

    turn = session.get("turn_count", 1)
    return CREDIT_OPENING_PROMPTS[turn % len(CREDIT_OPENING_PROMPTS)]


