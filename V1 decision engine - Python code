        return handle_planning_state(text, session)

        # Ask next missing signal
    if session.get("clarifying_question") is None and current_question not in COLLECTION_FLOW:
        next_q = get_next_missing_signal(session)
        if next_q:
            session["clarifying_question"] = next_q
