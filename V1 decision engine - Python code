def _detect_credit_emotion(text: str) -> str | None:
    text_lower = text.lower()
    scores = {}
    for emotion, signals in CREDIT_EMOTIONAL_SIGNALS.items():
        hits = sum(1 for s in signals if s in text_lower)
        if hits:
            scores[emotion] = hits
    return max(scores, key=scores.get) if scores else None


# AI generated code to help me generate th eright opening response based on the users emotions.
def _get_credit_opener(emotion: str, text: str) -> str:
    # Declare the variable before it is used.
    options = CREDIT_OPENERS[emotion]
    idx = int(hashlib.md5(text.encode()).hexdigest(), 16) % len(options)

    if emotion in CREDIT_EMOTIONAL_SIGNALS:
        return options[idx]

    return ""


def _extract_credit_score(text: str) -> int | None:
    patterns = [
        r"(?:my score is|score of|i have a|score:|credit score is|at)\s*(\d{3})",
        r"\b([3-8]\d{2})\b",
    ]
    for pattern in patterns:
        match = re.search(pattern, text.lower())
        if match:
            score = int(match.group(1))
            if 300 <= score <= 850:
                return score
    return None


