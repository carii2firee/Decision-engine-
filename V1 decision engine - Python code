# Clarification logic
def handle_clarification_state(text: str, session: dict) -> dict:
    session.setdefault("signals", {})
    current_question = session.get("clarifying_question")

    # ── CREDIT SCORE ─────────────────────────────────────────────
    if current_question == "credit_score":
        if session.get("score_shared"):
            session["signals"]["credit_score"] = session["score_shared"]
        else:
            score = _extract_credit_score(text)
            if score:
                session["signals"]["credit_score"] = score
                session["score_shared"] = score
            else:
                return {
                    "response": "Just type your score, something like 650 works perfectly.",
                    "mode": "credit",
                }

        session["clarifying_question"] = None
        pending = session.pop("pending_question", None)
        if pending:
            session["clarifying_question"] = pending
            return {
                "response": "Got it, your score is locked in. Ready to move on?",
                "mode": "credit",
            }

    # ── MAIN SIGNAL QUESTIONS ────────────────────────────────────
    elif current_question in ("has_credit_card", "missed_payments", "high_utilization"):
        yes_or_no = normalize_yes_no(text)
        if yes_or_no is None:
            return {
                "response": "Just entering yes or no works fine for me!",
                "mode": "credit",
            }

        session["signals"][current_question] = yes_or_no
        session["clarifying_question"] = None

        # has_credit_card no → skip utilization, go straight to collections
        if current_question == "has_credit_card" and yes_or_no == "no":
            session["signals"]["has_credit_card"] = "no"
            session["clarifying_question"] = "collections"
            return {
                "response": CLARIFY_QUESTIONS["collections"],
                "mode": "credit",
            }

        # ask next missing signal
        next_q = get_next_missing_signal(session)
        if next_q:
            session["clarifying_question"] = next_q
            return {
                "response": CLARIFY_QUESTIONS[next_q],
                "mode": "credit",
            }

    # ── COLLECTIONS QUESTION ─────────────────────────────────────
    elif current_question == "collections":
        yes_or_no = normalize_yes_no(text)
        if yes_or_no is None:
            return {
                "response": "Just entering yes or no works fine for me!",
                "mode": "credit",
            }

        session["signals"]["collections"] = yes_or_no

        if yes_or_no == "yes":
            # enter the collection flow
            next_key, next_text = get_next_collection_question(session)
            if next_key:
                session["clarifying_question"] = next_key
                return {
                    "response": next_text,
                    "mode": "credit",
                }

    # ── COLLECTION FLOW QUESTIONS ────────────────────────────────
    elif current_question in COLLECTION_FLOW:
        yes_or_no = normalize_yes_no(text)
        if yes_or_no is None:
            return {
                "response": "Just entering yes or no works fine for me!",
                "mode": "credit",
            }

        session[current_question] = yes_or_no

        next_key, next_text = get_next_collection_question(session)
        if next_key:
            session["clarifying_question"] = next_key
            return {
                "response": next_text,
                "mode": "credit",
            }

        # all collection questions answered → plan
        session["state"] = "planning"
        session["clarifying_question"] = None
        return handle_planning_state(text, session)

    # ── FALLBACK: ask next missing signal or go to planning ──────
    next_q = get_next_missing_signal(session)
    if next_q:
        session["clarifying_question"] = next_q
        return {
            "response": CLARIFY_QUESTIONS[next_q],
            "mode": "credit",
        }

    session["state"] = "planning"
    session["clarifying_question"] = None
    return handle_planning_state(text, session)



def handle_projection_logic(text: str, session: dict) -> dict:
    text_lower = text.lower()
    score = session.get("score_shared")

