def format_plan(plan: dict) -> str:
    lines = []

    for i, step in enumerate(plan.get("steps", []), 1):
        if isinstance(step, dict):
            lines.append(f"Step {i}: {step['title']}")
            lines.append(f"   {step['detail']}")
            lines.append("")
        else:
            lines.append(f"Step {i}: {step}")

    if plan.get("timeline"):
        lines.append(f"\nHere's the timeline: {plan['timeline']}")

    for warning in plan.get(" Next some things to be wary of", []):
        lines.append(f"\n⚠ {warning}")

    return "\n".join(lines)


def get_clarify_question(intent, topic, session):
    tree = CLARIFY_TREE.get(intent, {}).get(topic)

    if not tree:
        return None

    asked = session.get("clarify_asked", [])

    for key, question in tree:
        if key not in asked:
            session.setdefault("clarify_asked", []).append(key)
            return key, question

    return None



