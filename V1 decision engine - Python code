            if yes_or_no:
                next_key, next_text = get_next_missing_signal(session)
                session["current_question"] = next_key
                session["state"] = "clarifying"

                return {

                    "response": next_text,
                    "mode": "credit",
                }

            if not yes_or_no:
                session["state"] = "planning"
                return handle_planning_state(text, session)

            # Logic for allowing the collection questions to run if they're called properly
    elif current_question in COLLECTION_FLOW:
        yes_or_no = normalize_yes_no(text)

        if yes_or_no is None:
            return {
                "response": "Just entering yes or no works fine for me!",
                "mode": "credit",
            }

        session[current_question] = yes_or_no

        next_key, next_text = get_next_collection_question(session)

        # Loop through all the keys until it's at the final key
        if next_key:
            session["clarifying_question"] = next_key

            return {
                "response": next_text,
                "mode": "credit",
            }

            # When the session is done, make sure to switch to planning state to start building plans.
        session["state"] = "planning"
