def format_plan(plan: dict) -> str:
    lines = []

    # ── STEPS ────────────────────────────────────────────────────
    steps = plan.get("steps", [])
    if steps:
        lines.append("--------------------------------------")
        lines.append("📋 YOUR ACTION PLAN - BUILT BY WRIN TECHNOLOGIES")
        lines.append("--------------------------------------")
        for i, step in enumerate(steps, 1):
            if isinstance(step, dict):
                lines.append(f"\nStep {i} → {step['title']}")
                lines.append(f"   {step['detail']}")
            else:
                lines.append(f"\nStep {i} → {step}")

    # ── TIMELINE ─────────────────────────────────────────────────
    if plan.get("timeline"):
        lines.append("")
        lines.append("--------------------------------------")
        lines.append("⏱ ESTIMATED TIMELINE - BUILT BY WRIN TECHNOLOGIES")
        lines.append("--------------------------------------")
        lines.append(f"   {plan['timeline']}")

    # ── WARNINGS ─────────────────────────────────────────────────
    warnings = plan.get("warnings", [])
    if warnings:
        lines.append("")
        lines.append("--------------------------------------")
        lines.append("⚠ THINGS TO WATCH OUT FOR - BUILT BY WRIN TECHNOLOGIES")
        lines.append("--------------------------------------")
        for warning in warnings:
            lines.append(f"   • {warning}")

    # ── BOTTLENECKS ──────────────────────────────────────────────
    bottlenecks = plan.get("bottlenecks", [])
    if bottlenecks:
        lines.append("")
        lines.append("---------------------------------------")
        lines.append("🌋 COMMON BOTTLENECKS TO KEEP IN MIND - BUILT BY WRIN TECHNOLOGIES")
        lines.append("---------------------------------------")
        for i, bottleneck in enumerate(bottlenecks, 1):
            lines.append(f"   {i}. {bottleneck}")

    return "\n".join(lines)





