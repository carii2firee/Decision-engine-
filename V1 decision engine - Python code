def is_learn_question(text: str) -> bool:
    text_lower = text.lower().strip()

    learn_starters = [
        "what is", "what are", "what does",
        "how does", "how do", "how is",
        "explain", "define", "tell me about",
        "teach me", "i dont understand", "i'm confused",
        "what makes up", "what affects", "what impacts",
        "calculated", "mean", "meaning"
    ]

    if any(starter in text_lower for starter in learn_starters):
        return True

    # If user mentions a known credit topic in an educational way
    for topic, keywords in TOPIC_KEYWORDS.items():
        for keyword in keywords:
            if keyword and keyword in text_lower:
                if any(word in text_lower for word in ["what", "how", "explain", "why", "define", "mean"]):
                    return True

    return False


