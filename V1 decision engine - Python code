def record_feedback(session: dict, intent: str, topic_key: str | None, was_helpful: bool | None = None):
    """
    Appends to the session feedback log.
    was_helpful can be True/False from an explicit thumbs up/down,
    or None if we're just tracking usage.
    """
    session["feedback"].append({
        "The timestamp is:": datetime.datetime.now().isoformat(),
        "The intent is:": intent,
        "The topic is:": topic_key,
        "Was it helpful? ": was_helpful,
        "User stage:": session["stage"],
    })
    # Keep only the last 20 feedback entries
    if len(session["feedback"]) > 20:
        session["feedback"] = session["feedback"][-20:]


def get_feedback_summary(session: dict) -> dict:
    """
    Returns a simple summary of what's been discussed and what landed.
    Used internally — not shown to user.
    """
    feedback = session.get("feedback", [])
    if not feedback:
        return {}

    topics = [f["topic"] for f in feedback if f["topic"]]
    intents = [f["intent"] for f in feedback if f["intent"]]

    return {
        "most_discussed_topic": max(set(topics), key=topics.count) if topics else None,
        "primary_intent": max(set(intents), key=intents.count) if intents else None,
        "total_turns": len(feedback),
    }


