def _extract_credit_score(text: str) -> int | None:
    patterns = [
        r"(?:my score is|score of|i have a|score:|credit score is|at)\s*(\d{3})",
        r"\b([3-8]\d{2})\b",
    ]
    for pattern in patterns:
        match = re.search(pattern, text.lower())
        if match:
            score = int(match.group(1))
            if 300 <= score <= 850:
                return score
    return None


