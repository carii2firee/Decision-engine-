def is_projection(text):
    text = text.lower()

    # \b creates a word boundary so "if" doesn't match "gift"
    # we use a pipe | to join all keywords into one search
    # Bucket A: The "When/Future" signals
    future_signals = ["how long", "what will", "predict", "estimate", "projection", "timeline", "how fast"]

    # Bucket B: The "Score/Growth" signals
    growth_signals = ["score", "grow", "results", "improve", "benefit", "look like"]

    # The Logic: If it has one from both, trigger projection
    has_future = any(f in text for f in future_signals)
    has_growth = any(g in text for g in growth_signals)

    return has_future and has_growth


