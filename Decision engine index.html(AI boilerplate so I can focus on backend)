function renderScoreCapturedBadge(container, score) {
  const tier = score >= 740 ? {color:'#00C48C', label:'Current Range: High credit',  bg:'#E6FAF5', border:'#B2EDD8'}
             : score >= 670 ? {color:'#3B82F6', label:'Current Range: Stable credit',   bg:'#EFF6FF', border:'#BFDBFE'}
             : score >= 580 ? {color:'#F59E0B', label:'Current Range: Weak credit',   bg:'#FFFBEB', border:'#FDE68A'}
             :                {color:'#EF4444', label:'Current Range: Poor credit',   bg:'#FEF2F2', border:'#FCA5A5'};

  // Remove existing pill if already there
  const existing = document.getElementById('scorePill');
  if (existing) existing.remove();

  // Build the pill wrapper and display it on the screen fresh
  const pill = document.createElement('div');
  pill.id = 'scorePill';
  pill.style.cssText = `
    display:flex;align-items:center;gap:6px;
    background:${tier.bg};
    border:1.5px solid ${tier.border};
    border-radius:20px;
    padding:5px 12px;
    margin-left:auto;
    opacity:0;
    transform:scale(0.85);
    transition:opacity 0.4s ease, transform 0.4s ease;
  `;

  pill.innerHTML = `
    <span style="font-size:0.72rem;font-weight:800;color:${tier.color};
                 letter-spacing:0.04em;text-transform:uppercase;">${tier.label}</span>
    <span id="scoreCounter" style="font-family:'Space Grotesk',sans-serif;
                 font-size:1rem;font-weight:900;color:${tier.color};">0</span>
  `;

  // Inject into header
  document.querySelector('.credit-chat-header').appendChild(pill);

  // Animate in
  requestAnimationFrame(() => {
    pill.style.opacity = '1';
    pill.style.transform = 'scale(1)';
  });

  // Count up
  const counter = document.getElementById('scoreCounter');
  const duration = 900;
  const start = performance.now();

  function tick(now) {
    const progress = Math.min((now - start) / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    counter.textContent = Math.round(eased * score);
    if (progress < 1) requestAnimationFrame(tick);
    else counter.textContent = score;
  }

  requestAnimationFrame(tick);
}





