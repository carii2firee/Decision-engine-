  const qaBtn=document.createElement('button');qaBtn.className='video-qa-btn';qaBtn.textContent='Ask';
  async function askVideoQuestion(){const question=qaInput.value.trim();if(!question)return;qaInput.value='';qaDisplay.textContent='WRIN is thinking...';qaBtn.disabled=true;try{const res=await fetch('/video_qa',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({userId:currentUserId,question,videoId,timestamp:0,topic:title||''})});const data=await res.json();if(data.success){qaDisplay.textContent='';let i=0;const txt=data.response;const iv=setInterval(()=>{if(i<txt.length){qaDisplay.textContent=txt.substring(0,i+1);i++;}else clearInterval(iv);},10);}else{qaDisplay.textContent=`⚠️ ${data.error||'Could not get response.'}`;}}catch(err){qaDisplay.textContent=`❌ ${err.message}`;}finally{qaBtn.disabled=false;}}
  qaBtn.onclick=askVideoQuestion;qaInput.addEventListener('keydown',e=>{if(e.key==='Enter')askVideoQuestion();});
  qaRow.appendChild(qaInput);qaRow.appendChild(qaBtn);qaSection.appendChild(qaDisplay);qaSection.appendChild(qaRow);
  wrapper.appendChild(bar);wrapper.appendChild(iframe);wrapper.appendChild(qaSection);
  container.appendChild(wrapper);return true;
}

