function renderWealthSimulation(container,data){const sim=data.simulation;const sp=data.sp500;const wrapper=document.createElement('div');wrapper.style.cssText='width:100%;padding:4px 0;';if(sp){const isPos=!sp.change.includes('-');const spDiv=document.createElement('div');spDiv.className='sp-card';spDiv.innerHTML=`<div style="font-size:11px;font-weight:800;color:var(--blue);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:8px;">S&P 500 (SPY) — Live Market Data</div><div style="font-size:12px;color:var(--muted);font-weight:600;margin-bottom:12px;line-height:1.6;padding:10px;background:#fff;border-radius:10px;border:1px solid #BFDBFE;">💡 The S&P 500 tracks 500 of the biggest US companies. When you invest in an index fund, <strong style="color:var(--blue)">this is what you own a slice of.</strong></div><div style="display:flex;gap:10px;align-items:center;margin-bottom:8px;"><div><div style="font-size:11px;color:var(--muted);font-weight:700;">Current Price</div><div style="font-size:28px;font-weight:900;color:var(--blue);">$${parseFloat(sp.price).toFixed(2)}</div></div><div style="margin-left:auto;text-align:right;"><div style="color:${isPos?'var(--green)':'#EF4444'};font-weight:800;font-size:14px;">${isPos?'📈':'📉'} ${sp.change} (${sp.change_pct})</div></div></div>`;wrapper.appendChild(spDiv);}
const explain=document.createElement('div');explain.style.cssText='background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;margin-top:10px;font-size:13px;font-weight:600;line-height:1.7;color:var(--text);';explain.innerHTML=`<div style="font-weight:900;margin-bottom:8px;font-size:14px;">What does this mean? 🤔</div>Monthly: <strong>$${sim.monthly}</strong> for <strong>${sim.years} years</strong>, starting: <strong>$${sim.starting}</strong>.<br><div style="background:var(--green-light);border:1px solid var(--green-mid);padding:10px;border-radius:8px;margin-top:8px;text-align:center;">Invest <strong>$${sim.conservative.invested_total.toLocaleString()}</strong> → could become <strong style="color:var(--green);font-size:15px;">$${sim.moderate.future_value.toLocaleString()}</strong></div>`;wrapper.appendChild(explain);
renderWealthChart(wrapper,sim);const liveC=container||document.getElementById('budgetChatContainer');if(liveC){liveC.appendChild(wrapper);liveC.scrollTop=liveC.scrollHeight;}}

function renderWealthChart(wrapper,sim){
  const cw=document.createElement('div');cw.className='chart-card';cw.innerHTML=`<div class="chart-title">Wealth Growth Projection 📊</div>`;
  const canvas=document.createElement('canvas');canvas.style.cssText='width:100%;max-height:220px;';cw.appendChild(canvas);
  const sliderSection=document.createElement('div');sliderSection.style.cssText='margin-top:16px;padding:14px;background:var(--bg);border:1px solid var(--border);border-radius:12px;';
  sliderSection.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;"><span style="font-size:11px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;">🎚️ Adjust Monthly</span><span id="sliderMonthlyLabel" style="font-size:14px;font-weight:900;color:var(--green);">$${sim.monthly}/mo</span></div><input type="range" id="monthlySlider" min="10" max="${Math.max(sim.monthly*5,2000)}" step="10" value="${sim.monthly}" style="width:100%;accent-color:var(--green);height:6px;cursor:pointer;"/><div style="margin-top:14px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;" id="snapshotCards"></div><div style="margin-top:12px;padding:10px 14px;background:linear-gradient(135deg,var(--green-light),#EFF6FF);border:1px solid var(--green-mid);border-radius:10px;font-size:12px;font-weight:700;color:var(--text);line-height:1.7;" id="insightText"></div>`;
  cw.appendChild(sliderSection);wrapper.appendChild(cw);
  function buildData(monthly){const labels=[],consData=[],modData=[],aggData=[],invData=[];for(let y=0;y<=sim.years;y++){labels.push(`Yr ${y}`);consData.push(simulateWealth(sim.starting,monthly,0.06,y));modData.push(simulateWealth(sim.starting,monthly,0.09,y));aggData.push(simulateWealth(sim.starting,monthly,0.12,y));invData.push((monthly*y*12)+sim.starting);}return{labels,consData,modData,aggData,invData};}
  const snapshotEl=sliderSection.querySelector('#snapshotCards'),insightEl=sliderSection.querySelector('#insightText'),labelEl=sliderSection.querySelector('#sliderMonthlyLabel'),sliderEl=sliderSection.querySelector('#monthlySlider');
  function updateCards(monthly){const mid=Math.round(sim.years/2);const atMid=simulateWealth(sim.starting,monthly,0.10,mid);const atEnd=simulateWealth(sim.starting,monthly,0.10,sim.years);const atPlus=simulateWealth(sim.starting,monthly,0.10,sim.years+5);if(snapshotEl)snapshotEl.innerHTML=`<div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;"><div style="font-size:10px;font-weight:800;color:var(--muted);text-transform:uppercase;">In ${mid} yrs</div><div style="font-size:15px;font-weight:900;color:var(--amber);">$${atMid.toLocaleString()}</div></div><div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;"><div style="font-size:10px;font-weight:800;color:var(--muted);text-transform:uppercase;">In ${sim.years} yrs</div><div style="font-size:15px;font-weight:900;color:var(--blue);">$${atEnd.toLocaleString()}</div></div><div style="background:#fff;border:1px solid var(--green-mid);border-radius:10px;padding:10px;text-align:center;"><div style="font-size:10px;font-weight:800;color:var(--green);text-transform:uppercase;">+5 yrs more</div><div style="font-size:15px;font-weight:900;color:var(--green);">$${atPlus.toLocaleString()}</div></div>`;const invested=monthly*sim.years*12+sim.starting;const growth=atEnd-invested;if(insightEl)insightEl.innerHTML=`💡 At <strong>$${monthly}/month</strong> — you put in <strong>$${invested.toLocaleString()}</strong> and compound interest adds <strong style="color:var(--green);">$${growth.toLocaleString()}</strong> on top.`;}
  const d=buildData(sim.monthly);const chart=new Chart(canvas,{type:'line',data:{labels:d.labels,datasets:[{label:'Just Cash',data:d.invData,borderColor:'rgba(100,116,139,0.4)',borderDash:[5,5],fill:true,backgroundColor:'rgba(100,116,139,0.04)',tension:0.4,pointRadius:0},{label:'6% Conservative',data:d.consData,borderColor:'#F59E0B',fill:false,tension:0.4,pointRadius:0},{label:'9% Moderate',data:d.modData,borderColor:'#3B82F6',fill:false,tension:0.4,pointRadius:0,borderWidth:2},{label:'12% S&P Recent',data:d.aggData,borderColor:'#00C48C',fill:false,tension:0.4,pointRadius:0,borderWidth:3}]},options:{responsive:true,interaction:{mode:'index',intersect:false},animation:{duration:300},plugins:{legend:{position:'bottom',labels:{color:'#64748B',font:{size:10,family:'Nunito',weight:'700'}}},tooltip:{callbacks:{label:ctx=>` ${ctx.dataset.label}: $${Math.round(ctx.raw).toLocaleString()}`}}},scales:{y:{ticks:{callback:val=>`$${(val/1000).toFixed(0)}k`,color:'#94A3B8',font:{size:10}},grid:{color:'rgba(0,0,0,0.04)'}},x:{ticks:{color:'#94A3B8',font:{size:10}},grid:{display:false}}}}});
