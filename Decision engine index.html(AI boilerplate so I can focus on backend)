    wrap.appendChild(avatar);wrap.appendChild(bubble);container.appendChild(wrap);container.scrollTop=container.scrollHeight;
    const lines=text.split('\n');const embedLines=[];const linkLines=[];const ytCount=lines.filter(l=>l.match(/https?:\/\/.*youtu/)).length;const isAudiobookList=ytCount>1;const textLines=[];
    for(let li=0;li<lines.length;li++){const line=lines[li];const m=line.match(/(https?:\/\/(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11}[^\s]*))/);if(m){let title='';if(textLines.length>0){const prevLine=textLines[textLines.length-1];if(!prevLine.match(/https?:\/\//)){title=prevLine.replace(/^[\s•\-]+/,'').trim();textLines.pop();}}if(isAudiobookList)linkLines.push({url:m[1],title});else embedLines.push({url:m[1],title});}else{textLines.push(line);}}
    const clean=textLines.join('\n');let i=0;
