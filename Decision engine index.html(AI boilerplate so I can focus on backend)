function renderYoutubeEmbed(container,url,title){
  const match=url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  if(!match)return false;const videoId=match[1];
  const wrapper=document.createElement('div');wrapper.className='video-wrapper';
  const bar=document.createElement('div');bar.className='video-title-bar';bar.textContent=`▶ ${title||'WRIN Resource'}`;
  const iframe=document.createElement('iframe');iframe.setAttribute('width','100%');iframe.setAttribute('height','200');iframe.setAttribute('frameborder','0');iframe.style.cssText='width:100% !important;height:200px !important;min-height:200px;border:none;display:block;';iframe.src=`https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1`;iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;
  const qaSection=document.createElement('div');qaSection.className='video-qa-section';
